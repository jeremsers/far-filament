---
import { Image } from "astro:assets";
import logo from "../images/logo5.avif";
import logomobile from "../images/logo5.avif";
---

<header class="header-main">
	<div class="logo">
		<a href="/" class="logo-link">
			<Image src={logo} alt="logo" class="logo-img" />
			<Image src={logomobile} alt="logo" class="logo-img-mobile" />
		</a>
	</div>
	<button
		class="mobile-menu-toggle"
		aria-label="Menu"
		aria-expanded="false"
		aria-controls="main-nav"
	>
		<span class="hamburger"></span>
	</button>
	<nav id="main-nav">
		<a href="/qui" class="nav-link"><span>À propos</span></a>
		<div class="nav-item has-dropdown">
			<button class="nav-link dropdown-toggle" aria-expanded="false">
				<span>Accompagnements</span>
				<svg class="chevron" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><polyline points="6 9 12 15 18 9"></polyline></svg>
			</button>
			<div class="dropdown-menu">
				<a href="/burnout" class="dropdown-link">Burnout & Carrière</a>
				<a href="/rupture" class="dropdown-link">Rupture & Deuil</a>
			</div>
		</div>
		<div class="nav-item has-dropdown">
			<button class="nav-link dropdown-toggle" aria-expanded="false">
				<span>Packs de soutien</span>
				<svg class="chevron" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><polyline points="6 9 12 15 18 9"></polyline></svg>
			</button>
			<div class="dropdown-menu">
				<a href="/pack-burnout" class="dropdown-link">Pack Burnout</a>
				<a href="/pack-rupture" class="dropdown-link">Pack Rupture</a>
			</div>
		</div>
		<a href="/blog/all/1" class="nav-link"><span>Blog</span></a>
		<a href="/#dispatcher" class="btn cta-btn">Choisir mon parcours</a>
	</nav>
</header>

<script>
	const mobileMenuToggle = document.querySelector(".mobile-menu-toggle");
	const nav = document.querySelector("#main-nav");
	const header = document.querySelector(".header-main");

	// Toggle mobile menu
	mobileMenuToggle?.addEventListener("click", () => {
		const isExpanded = mobileMenuToggle.getAttribute("aria-expanded") === "true";
		mobileMenuToggle.setAttribute(
			"aria-expanded",
			!isExpanded ? "true" : "false"
		);
		nav?.classList.toggle("active");
		header?.classList.toggle("nav-open");
	});

	// Close menu when clicking outside
	document.addEventListener("click", (e) => {
		const target = e.target as HTMLElement;
		if (!target.closest("header") && nav?.classList.contains("active")) {
			nav.classList.remove("active");
			mobileMenuToggle?.setAttribute("aria-expanded", "false");
			header?.classList.remove("nav-open");
		}
	});

	// Dropdown functionality for mobile
	const dropdownToggles = document.querySelectorAll(".dropdown-toggle");
	dropdownToggles.forEach(toggle => {
		toggle.addEventListener("click", (e) => {
			e.preventDefault();
			const parent = toggle.closest(".has-dropdown");
			
			// Close other open dropdowns
			document.querySelectorAll(".has-dropdown.open").forEach(dropdown => {
				if (dropdown !== parent) {
					dropdown.classList.remove("open");
					dropdown.querySelector(".dropdown-toggle")?.setAttribute("aria-expanded", "false");
				}
			});

			const isOpen = parent?.classList.toggle("open");
			toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
		});
	});

	// Close menu when clicking on a standard link
	nav?.addEventListener("click", (e) => {
		const target = e.target as HTMLElement;
		// Do not close if clicking on a dropdown toggle
		if (target.closest(".dropdown-toggle")) return;

		// Check if the target is a link or is inside a link
		if (target.tagName === "A" || target.closest("a")) {
			nav.classList.remove("active");
			mobileMenuToggle?.setAttribute("aria-expanded", "false");
			header?.classList.remove("nav-open");
			
			// Close all dropdowns
			document.querySelectorAll(".has-dropdown.open").forEach(dropdown => {
				dropdown.classList.remove("open");
				dropdown.querySelector(".dropdown-toggle")?.setAttribute("aria-expanded", "false");
			});
		}
	});
</script>

<style lang="scss">
	.header-main {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 clamp(15px, 3vw, 30px);
		background-color: $bg-color;
		height: clamp(60px, 10vh, 80px);
		position: relative;
		z-index: 1000;
		box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
		
		&.nav-open {
			background-color: $bg-color;
		}
	}
	
	.logo {
		height:	90%;
		width: 280px;
		z-index: 1001;
		transition: all 0.3s ease;
		position: relative;
		display: flex;
		align-items: center;

		&-link {
			display: flex;
			align-items: center;
			height: 100%;
			width: 100%;
		}

		&-img {
			height: 100%;
			width: 100%;
			object-fit: contain;
			object-position: left center;
			transition: transform 0.4s ease;
			display: block;

			@media (max-width: 768px) {
				display: none;
			}

			&:hover {
				transform: translateY(-2px);
			}
		}

		&-img-mobile {
			height: 100%;
			width: auto;
			object-fit: contain;
			object-position: left center;
			transition: transform 0.4s ease;
			display: none;

			@media (max-width: 768px) {
				display: block;
			}

			&:hover {
				transform: translateY(-2px);
			}
		}
	}

	.mobile-menu-toggle {
		display: none;
		background: none;
		border: none;
		padding: 10px;
		cursor: pointer;
		z-index: 1001;
		transition: transform 0.3s ease;

		&:hover {
			transform: scale(1.1);
		}

		.hamburger {
			display: block;
			width: 24px;
			height: 2px;
			background-color: $text-color;
			position: relative;
			transition: all 0.3s ease;
			left: 0;
			transform-origin: center;

			&::before,
			&::after {
				content: "";
				position: absolute;
				width: 24px;
				height: 2px;
				background-color: $text-color;
				transition: all 0.3s ease;
				left: 0;
				transform-origin: center;
			}

			&::before {
				top: -8px;
			}

			&::after {
				bottom: -8px;
			}
		}

		&[aria-expanded="true"] {
			.hamburger {
				background-color: transparent;

				&::before {
					transform: rotate(45deg) translate(5.5px, 5.5px);
				}

				&::after {
					transform: rotate(-45deg) translate(5.5px, -5.5px);
				}
			}
		}
	}

	nav {
		display: flex;
		align-items: center;
		gap: clamp(15px, 2vw, 30px);

		.nav-link {
			color: $text-color;
			text-decoration: none;
			font-size: clamp(0.85rem, 1.5vw, 1.1rem);
			transition: all 0.3s ease;
			position: relative;
			padding: 5px 0;

			span {
				position: relative;
				z-index: 1;
			}

			&::after {
				content: "";
				position: absolute;
				bottom: 0;
				left: 0;
				width: 0;
				height: 2px;
				background-color: $secondary-color;
				transition: width 0.3s ease;
			}

			&:hover {
				color: $text-white;

				&::after {
					width: 100%;
				}
			}
		}

		.nav-item {
			position: relative;
			display: flex;
			align-items: center;

			.dropdown-toggle {
				background: none;
				border: none;
				cursor: pointer;
				display: flex;
				align-items: center;
				gap: 5px;
				font-family: inherit;
				
				.chevron {
					transition: transform 0.3s ease;
				}
			}

			.dropdown-menu {
				position: absolute;
				top: 100%;
				left: 50%;
				transform: translateX(-50%) translateY(10px);
				background-color: $bg-color;
				border-radius: 8px;
				box-shadow: 0 4px 15px rgba(0,0,0,0.1);
				padding: 10px 0;
				min-width: 200px;
				opacity: 0;
				visibility: hidden;
				transition: all 0.3s ease;
				z-index: 100;
				display: flex;
				flex-direction: column;

				.dropdown-link {
					padding: 10px 20px;
					color: $text-color;
					text-decoration: none;
					font-size: 0.95rem;
					transition: background-color 0.2s ease, color 0.2s ease;
					text-align: center;
					
					&:hover {
						background-color: rgba(255,255,255,0.1);
						color: $text-white;
					}
				}
			}

			&:hover .dropdown-menu {
				opacity: 1;
				visibility: visible;
				transform: translateX(-50%) translateY(0);
			}

			&:hover .chevron {
				transform: rotate(180deg);
			}
		}

		.cta-btn {
			display: inline-block;
			background-color: $primary-color;
			color: $text-white;
			padding: clamp(8px, 1.5vw, 12px) clamp(15px, 2vw, 25px);
			border-radius: 30px;
			font-weight: 600;
			font-size: clamp(0.85rem, 1.5vw, 1rem);
			transition: all 0.3s ease;
			white-space: nowrap;
			border: 2px solid transparent;

			&:hover {
				transform: translateY(-3px);
				box-shadow: 0 7px 14px rgba(0, 0, 0, 0.2);
				background-color: darken($primary-color, 5%);
			}

			&:active {
				transform: translateY(-1px);
				box-shadow: 0 3px 8px rgba(0, 0, 0, 0.2);
			}
		}
	}

	@media (max-width: 768px) {
		.mobile-menu-toggle {
			display: block;
		}
		.header-main {
			background-color: $bg-color;
		}
		nav {
			position: fixed;
			top: 0;
			right: -100%;
			width: 100%;
			height: 100vh;
			background-color: $bg-color;
			flex-direction: column;
			justify-content: center;
			padding: 80px 20px 20px;
			transition: all 0.4s cubic-bezier(0.77, 0, 0.175, 1);
			opacity: 0;
			visibility: hidden;

			&.active {
				right: 0;
				opacity: 1;
				visibility: visible;
			}

			.nav-link {
				font-size: clamp(1.1rem, 4vw, 1.3rem);
				padding: 15px;
				width: 100%;
				text-align: center;
				margin: 5px 0;
				color: $text-color;

				&::after {
					display: none;
				}

				&:hover {
					background-color: rgba(255, 255, 255, 0.1);
					border-radius: 8px;
				}
			}

			.nav-item {
				width: 100%;
				flex-direction: column;
				
				.dropdown-toggle {
					width: 100%;
					justify-content: center;
					padding: 15px;
					font-size: clamp(1.1rem, 4vw, 1.3rem);
					margin: 5px 0;
					
					&[aria-expanded="true"] .chevron {
						transform: rotate(180deg);
					}
				}

				.dropdown-menu {
					position: static;
					transform: none;
					box-shadow: none;
					background-color: rgba(0,0,0,0.05);
					width: 100%;
					display: none;
					opacity: 1;
					visibility: visible;
					padding: 0;
					
					.dropdown-link {
						padding: 12px 20px;
						font-size: 1rem;
					}
				}

				&.open .dropdown-menu {
					display: flex;
				}

				&:hover .dropdown-menu {
					transform: none;
				}
			}

			.cta-btn {
				margin-top: 20px;
				width: 100%;
				max-width: 300px;
				font-size: clamp(0.9rem, 3vw, 1rem);
				text-align: center;
			}
		}
	}
</style>
